[node name="Interactable" type="Area2D" unique_id=875527561]
editor_description = "Emits 'interacted' signal when the player presses the interact key inside the trigger area.

Setup:
- Connect 'interacted' signal to the first step of your tutorial or any interactable target (e.g. show_tutorial()).
- Connect the end-of-interaction signal from your target (e.g. tutorial_end) back to '_on_interaction_end()' on this node to properly disable the interaction.

Optional:
- Enable 'can_reinteract' to allow repeated interactions after a cooldown.
"
collision_layer = 128
collision_mask = 0
script = ExtResource("1_4t2mx")

[node name="CooldownTimer" type="Timer" parent="." unique_id=1212475603]
unique_name_in_owner = true
one_shot = true

[connection signal="timeout" from="CooldownTimer" to="." method="_on_cooldown_timer_timeout"]
